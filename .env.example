PORT=5000
MONGO_URI=mongodb://localhost:27017/mern_assignment
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1h
NODE_ENV=development

# Optional: restrict CORS (comma-separated origins) or leave unset for "*"
# CORS_ORIGIN=http://localhost:3000

# Optional: used by Swagger UI "servers" URL
# SWAGGER_SERVER_URL=http://localhost:5000

# Optional: used by `npm run create-admin` (or pass --email/--password flags instead)
# ADMIN_NAME=Admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me_strong_password
